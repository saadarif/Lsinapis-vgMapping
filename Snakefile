#Function to load metadata with robust handling of missing files and columns
def load_metadata(file_key, source_name):
    file_path = config.get(file_key)
    expected_cols = ['sample_id', 'run_id','fq1', 'fq2', 'library', 'platform']
    
    if not file_path or not os.path.exists(file_path):
        # Return a truly empty dataframe with no rows
        return pd.DataFrame(columns=expected_cols)
    
    sep = '\t' if file_path.endswith(('.tsv', '.txt')) else ','
    df = pd.read_csv(file_path, sep=sep)
    
    # Only keep rows that have a sample_id
    df = df.dropna(subset=['sample_id'])
    
    if 'fq2' not in df.columns:
        df['fq2'] = "unknown"
        
    df = df.fillna("unknown")
    df['source'] = source_name
    return df

# Load both (or neither)
modern_df = load_metadata("modern_csv", "modern")
hist_df = load_metadata("historical_csv", "historical")

# Combine datasets
samples_df = pd.concat([modern_df, hist_df], ignore_index=True)

# REMOVE "unknown" rows that were generated by empty files or missing columns
samples_df = samples_df[samples_df['sample_id'] != "unknown"]

# Safety Check: Now truly check if there is real data left
if samples_df.empty:
    print("\nERROR: No valid samples found. Please check your metadata files.\n")
    sys.exit(1)
# Safety Check: If both files are missing or empty, stop and warn the user.
if samples_df.empty:
    print("\nERROR: No samples found. Check 'modern_csv' and 'historical_csv' in config.yaml\n")
    sys.exit(1)

# List of all unique Sample IDs for expansion logic
SAMPLES = samples_df['sample_id'].unique()

