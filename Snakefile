# ==============================================================================
configfile: "config.yaml"
# Load reference name from config
REF_NAME = config.get("ref_name", "ref")

# Regex breakdown:
# [^_]+ means "one or more characters that are NOT an underscore"
# .+     means "one or more of any character"
wildcard_constraints:
    sample_id = "[^.]+",  # Stop at the first dot
    run_id    = "[^.]+",  # Stop at the next dot
    ref_name  = "[^.]+"   # Stop at the dot before .bam


#ADD rules here
include: "workflow/rules/mapping.smk"
